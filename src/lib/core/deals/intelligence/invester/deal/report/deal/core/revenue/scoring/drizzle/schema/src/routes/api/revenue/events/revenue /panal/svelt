<script>
  let events = [];
  let summary = [];

  async function load() {
    const e = await fetch("/api/revenue/events");
    events = await e.json();

    const s = await fetch("/api/summary");
    summary = await s.json();
  }

  load();
</script>

<h1>Revenue Engine</h1>

<div class="grid">
  {#each summary as row}
    <div class="card">
      <div class="label">{row.walletType}</div>
      <div class="value">${row.total}</div>
    </div>
  {/each}
</div>

<h2>Recent Revenue Events</h2>

<div class="events">
  {#each events as ev}
    <div class="event">
      <div class="amount">${ev.amount}</div>
      <div class="alloc">
        {#each Object.entries(JSON.parse(ev.metadata)) as [k,v]}
          <span>{k}: ${v}</span>
        {/each}
      </div>
      <div class="time">{new Date(ev.createdAt).toLocaleString()}</div>
    </div>
  {/each}
</div>

